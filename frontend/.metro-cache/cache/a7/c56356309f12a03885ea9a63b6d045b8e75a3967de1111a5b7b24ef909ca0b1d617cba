rn phone;\n  }\n  function fmtDatePrint(ts) {\n    if (!ts) return '—';\n    const d = new Date(ts);\n    return `${d.getDate().toString().padStart(2, '0')} ${MONTHS[d.getMonth()]} ${d.getFullYear()}`;\n  }\n  function fmtTimePrint(ts) {\n    if (!ts) return '—';\n    const d = new Date(ts);\n    const h = d.getHours();\n    const m = d.getMinutes();\n    const ampm = h >= 12 ? 'PM' : 'AM';\n    const h12 = h % 12 || 12;\n    return `${h12}:${m.toString().padStart(2, '0')} ${ampm}`;\n  }\n  function fullDateTimePrint() {\n    const now = new Date();\n    return `${fmtDatePrint(now.getTime())} at ${fmtTimePrint(now.getTime())}`;\n  }\n  function buildLetterhead(data) {\n    const contactParts = [];\n    if (data.enrollmentNumber) contactParts.push(`Bar ID: ${data.enrollmentNumber}`);\n    if (data.phone) contactParts.push(fmtPhone(data.phone));\n    if (data.email) contactParts.push(data.email);\n    const contactLine = contactParts.join(' &nbsp;|&nbsp; ');\n    const barLine = data.barCouncil ? `Advocate &nbsp;|&nbsp; ${data.barCouncil}` : 'Advocate';\n    return `\n    <div class=\"letterhead\">\n      <div class=\"letterhead-name\">${data.advocateName}</div>\n      <div class=\"letterhead-bar\">${barLine}</div>\n      ${contactLine ? `<div class=\"letterhead-contact\">${contactLine}</div>` : ''}\n      <div class=\"letterhead-divider\"></div>\n      <div class=\"letterhead-generated\">Generated on: ${fullDateTimePrint()}</div>\n      <div class=\"letterhead-divider\"></div>\n    </div>\n  `;\n  }\n  const printCSS = `\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n  body {\n    font-family: Arial, sans-serif;\n    font-size: 12px;\n    color: #000;\n    background: #fff;\n    padding: 32px 40px;\n    line-height: 1.5;\n  }\n  .letterhead {\n    margin-bottom: 24px;\n  }\n  .letterhead-name {\n    font-size: 20px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n  }\n  .letterhead-bar {\n    font-size: 12px;\n    color: #333;\n    margin-top: 4px;\n  }