Date();\n    const dateStr = now.toLocaleDateString('en-IN', {\n      weekday: 'long',\n      year: 'numeric',\n      month: 'long',\n      day: 'numeric'\n    });\n\n    // Case rows\n    const caseRows = data.cases.length === 0 ? '<tr><td colspan=\"6\" class=\"empty\">No cases recorded.</td></tr>' : data.cases.map(c => {\n      const client = data.clients.find(cl => cl.id === c.clientId);\n      return `<tr>\n          <td>${c.caseNumber}</td>\n          <td>${c.title}</td>\n          <td>${c.courtName}</td>\n          <td><span class=\"badge\">${c.status}</span></td>\n          <td>${c.caseType}</td>\n          <td>${client?.name || c.clientName || '—'}</td>\n        </tr>`;\n    }).join('');\n\n    // Client rows\n    const clientRows = data.clients.length === 0 ? '<tr><td colspan=\"5\" class=\"empty\">No clients recorded.</td></tr>' : data.clients.map(cl => `<tr>\n        <td>${cl.name}</td>\n        <td>${cl.phone}</td>\n        <td>${cl.clientType}</td>\n        <td>${cl.city || '—'}</td>\n        <td>${data.cases.filter(c => c.clientId === cl.id).length}</td>\n      </tr>`).join('');\n\n    // Hearing rows (last 30)\n    const sortedHearings = [...data.hearings].sort((a, b) => b.hearingDate - a.hearingDate).slice(0, 50);\n    const hearingRows = sortedHearings.length === 0 ? '<tr><td colspan=\"5\" class=\"empty\">No hearings recorded.</td></tr>' : sortedHearings.map(h => {\n      const c = data.cases.find(x => x.id === h.caseId);\n      return `<tr>\n          <td>${fmtDate(h.hearingDate)}</td>\n          <td>${c?.caseNumber || '—'}</td>\n          <td>${c?.courtName || '—'}</td>\n          <td>${h.purpose || '—'}</td>\n          <td>${h.outcome || 'Pending'}</td>\n        </tr>`;\n    }).join('');\n    return `<!DOCTYPE html>\n<html>\n<head><meta charset=\"utf-8\"><style>${baseCSS}\n  .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }\n</style></head>\n<body>\n  <div class=\"page-header\">\n    <div class